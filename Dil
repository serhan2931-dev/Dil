            end)
        end

        if Flags.EventCollector and HRP then
            pcall(function()
                for _, obj in ipairs(Workspace:GetChildren()) do
                    if string.find(string.lower(obj.Name), "seed") or string.find(string.lower(obj.Name), "moon") then
