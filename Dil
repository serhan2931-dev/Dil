local function IsNight()
    local clockTime = Lighting.ClockTime
    return clockTime >= 18 or clockTime <= 6
end

-- --- CACHED PROXIMITY PROMPT ENGINE ---
-- Instead of scanning everything, we selectively query objects near the player
local function GetNearbyPrompts(keyword)
    local targets = {}
    if not HRP then return targets end
    
    -- Optimize scan area by looking directly in main workspace containers if possible
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("ProximityPrompt") and string.find(string.lower(obj.Name), keyword) then
            table.insert(targets, obj)
        elseif string.find(string.lower(obj.Name), "plot") or string.find(string.lower(obj.Name), "garden") then
            for _, subObj in ipairs(obj:GetDescendants()) do
                if subObj:IsA("ProximityPrompt") and string.find(string.lower(subObj.Name), keyword) then
                    table.insert(targets, subObj)
                end
            end
        end
    end
    return targets
